{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.3" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "id": null,
  "title": "Loki Logs",
  "uid": "agora-loki-logs",
  "version": 1,
  "schemaVersion": 39,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Namespace",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\".+\"}[5m]))",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} |= \"error\" [5m]))",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Log Level Distribution",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({namespace=\"city-services\"} [5m]))",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=\"city-services\"} |= \"error\" | logfmt | line_format \"{{.pod}}: {{.msg}}\"",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 5,
      "title": "Top Error Messages",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (msg) (count_over_time({namespace=\"city-services\"} |= \"error\" | logfmt [1h])))",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    }
  ]
}
