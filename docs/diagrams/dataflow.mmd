---
title: Agora Platform — End-to-End Data Flow
---
flowchart TB
    subgraph Devices["Physical Devices (10,000+)"]
        V["🚗 Vehicles<br/>500-1,000 AVs<br/>10Hz telemetry"]
        S["📡 Sensors<br/>10,000+ IoT<br/>1Hz readings"]
        T["🚦 Traffic Signals<br/>Smart intersections<br/>V2X capable"]
        B["🏢 Buildings<br/>HVAC, Energy,<br/>Occupancy"]
    end

    subgraph Gateway["Layer 1: Device Gateway (on EKS)"]
        MTLS["🔒 mTLS Auth<br/>Device certificate<br/>validation"]
        SCHEMA["✅ Schema Validation<br/>Reject malformed<br/>messages"]
        BUF["📦 Buffering<br/>Local queue if<br/>cloud is slow"]
        COMP["🗜️ Compression<br/>Snappy/LZ4<br/>Reduce bandwidth"]
    end

    subgraph Edge["Edge Processing (&lt;10ms)"]
        EDGE["🧠 Edge Node<br/>Local traffic optimizer<br/>No cloud round-trip<br/>Safe mode fallback"]
    end

    subgraph MSK["Layer 2: Amazon MSK Express (3 Brokers × express.m7g.large)"]
        VEHICLE["📊 vehicle.telemetry<br/>10K+ msg/sec<br/>12 partitions<br/>Key: vehicle_type<br/>Retention: 7d"]
        ENV["🌤️ sensor.environmental<br/>5K+ msg/sec<br/>6 partitions<br/>Key: district<br/>Retention: 7d"]
        SIGNAL["🚦 signal.events<br/>2K+ msg/sec<br/>6 partitions<br/>Key: intersection_id<br/>Retention: 7d"]
        INC["🚨 incidents<br/>100 msg/sec<br/>1 partition<br/>Retention: 30d"]
    end

    subgraph Connect["Kafka Connect S3 Sink"]
        S3_SINK_V["📦 Archive vehicle.telemetry<br/>→ S3 data lake<br/>AVRO format<br/>Hourly rotation"]
        S3_SINK_E["📦 Archive sensor.environmental<br/>→ S3 data lake"]
        S3_SINK_S["📦 Archive signal.events<br/>→ S3 data lake"]
        S3_SINK_I["📦 Archive incidents<br/>→ S3 data lake"]
    end

    subgraph Processors["Layer 3: Stream Processors (Flink/Kafka Streams on EKS)"]
        TO["🚦 Traffic Optimizer<br/>3-10 pods<br/>5s sliding window<br/>SLO: &lt;100ms"]
        AD["🔍 Anomaly Detector<br/>2-8 pods<br/>ML inference<br/>SLO: &lt;500ms"]
        EO["⚡ Energy Optimizer<br/>2-6 pods<br/>Weather + consumption<br/>SLO: &lt;1s"]
        DB["🔐 Data Broker<br/>5-20 pods<br/>Anonymization<br/>All 60K msg/sec pass through"]
    end

    subgraph OutputTopics["Output Topics (MSK)"]
        CMD["📋 signal.commands<br/>Traffic signal instructions<br/>6 partitions"]
        ANON["🕵️ data.anonymized.vehicle<br/>PII stripped, grid-rounded<br/>12 partitions"]
        INV["📱 data.inventor.traffic<br/>Sector averages only<br/>3 partitions"]
        ALERT["🔔 alerts.notifications<br/>Safety alerts, anomaly reports<br/>1 partition"]
        DLQ["⚠️ dlq.all<br/>Failed messages<br/>1 partition"]
    end

    subgraph Storage["Layer 4: Data Storage"]
        TS["⏱️ Amazon Timestream<br/>Time-series metrics<br/>Speed, temp, energy<br/>Range queries"]
        AURORA["🗄️ Aurora PostgreSQL<br/>Transactional data<br/>Device registry, state<br/>Multi-AZ, KMS"]
        S3_RAW["🗃️ S3: Raw Data Lake<br/>AVRO archives<br/>KMS encrypted<br/>Lifecycle → Glacier"]
        S3_PROC["📂 S3: Processed Data<br/>Anonymized datasets<br/>Per-inventor IAM<br/>30d retention"]
        S3_BACKUP["💾 S3: Backups<br/>Terraform state<br/>RDS exports<br/>DR: cross-region"]
    end

    subgraph DLQ_Processor["Dead Letter Queue"]
        DLP["📥 DLQ Processor<br/>Classify failures<br/>Schema violations → notify<br/>Transient → retry 3x<br/>Poison pills → alert"]
    end

    subgraph Monitoring["Observability"]
        CW["📊 CloudWatch<br/>Infra dashboards<br/>MSK/RDS/EKS metrics"]
        PROM["📈 Prometheus (on EKS)<br/>App metrics<br/>Consumer lag<br/>Processing latency"]
        GRAF["📉 Grafana<br/>Unified dashboards<br/>Traffic / Energy / System"]
        SNS["📢 SNS Alerts<br/>Critical → PagerDuty<br/>Warning → Slack<br/>Info → Log"]
    end

    %% Device → Gateway
    V -->|"mTLS (TLS 1.3)"| MTLS
    S -->|"mTLS"| MTLS
    T -->|"mTLS"| MTLS
    B -->|"mTLS"| MTLS
    MTLS --> SCHEMA --> BUF --> COMP

    %% Gateway → MSK
    COMP -->|"Kafka Produce (IAM auth port 9098)"| VEHICLE
    COMP --> ENV
    COMP --> SIGNAL

    %% Edge processing (parallel path)
    T -.->|"V2X direct"| EDGE
    EDGE -.->|"sync 100ms"| SIGNAL
    EDGE -.-> CMD

    %% MSK → S3 Sink
    VEHICLE --- S3_SINK_V
    ENV --- S3_SINK_E
    SIGNAL --- S3_SINK_S
    INC --- S3_SINK_I
    S3_SINK_V --> S3_RAW
    S3_SINK_E --> S3_RAW
    S3_SINK_S --> S3_RAW
    S3_SINK_I --> S3_RAW

    %% MSK → Processors
    VEHICLE --> TO
    VEHICLE --> AD
    VEHICLE --> DB
    ENV --> EO
    ENV --> DB
    SIGNAL --> TO
    SIGNAL --> DB
    INC --> AD

    %% Processors → Output Topics
    TO --> CMD
    TO -->|"anomalies"| INC
    AD --> INC
    AD --> ALERT
    EO --> ALERT
    DB --> ANON
    DB --> INV
    DB -->|"failures"| DLQ

    %% Output Topics → Storage
    CMD --> TS
    ANON --> S3_PROC
    INV --> S3_PROC
    ALERT --> AURORA
    INC --> AURORA

    %% S3 → Downstream
    S3_RAW -->|"Athena queries"| AURORA
    S3_PROC --> AURORA

    %% DLQ
    DLQ --> DLP
    DLP -->|"replay"| VEHICLE
    DLP -->|"alert"| ALERT

    %% Monitoring (all components)
    MSK -.->|"CloudWatch metrics"| CW
    Processors -.->|"Prometheus metrics"| PROM
    Connect -.->|"connector status"| CW
    CW -.-> GRAF
    PROM -.-> GRAF
    CW -.-> SNS
